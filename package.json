{
  "name": "@psmsun/video-utils",
  "version": "1.0.0",
  "description": "YouTube and VK video ID extraction utilities and a generic VideoEmbed React component",
  "source": "src/index.js",
  "main": "dist/index.js",
  "module": "dist/index.module.js",
  "exports": {
    ".": {
      "import": "./dist/index.module.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "microbundle --jsx React.createElement --jsxFragment React.Fragment",
    "dev": "microbundle watch --jsx React.createElement --jsxFragment React.Fragment",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "devDependencies": {
    "microbundle": "latest",
    "react": "^18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/psmsun/video-utils.git"
  },
  "homepage": "https://github.com/psmsun/video-utils#readme",
  "bugs": {
    "url": "https://github.com/psmsun/video-utils/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "youtube",
    "vk",
    "video",
    "react",
    "embed",
    "video-id"
  ],
  "license": "MIT"
}
